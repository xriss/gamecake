cd `dirname $0`

vagrant up

# this is slow so enable it only when you want to bump the emsdk version
vagrant ssh -c " /gamecake/build/install-emsdk /home/vagrant/ "

vagrant ssh -c " source /home/vagrant/emsdk/emsdk_env.sh ; cd /gamecake ; build/make --gcc=emcc $* "

if [[ -v VBOX_KEEP ]] ; then
	echo "you set VBOX_KEEP so keeping vbox up for faster next use"
else
	echo "you have not set VBOX_KEEP so halting vbox"
	vagrant halt
fi
